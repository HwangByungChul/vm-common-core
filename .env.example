# ────────────────────────────────────────────────────────────────
# vm-common-core 환경변수 명세서
# 이 파일을 복사하여 .env 파일을 만들고, 각 값을 입력하세요.
# cp .env.example .env
# ────────────────────────────────────────────────────────────────

# ── [필수] JWT 인증 ──────────────────────────────────────────────
# 최소 32자 이상의 임의 문자열 권장
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this

# ── [필수] Google OAuth 2.0 ──────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 발급
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── [필수] Gmail SMTP 알림 ───────────────────────────────────────
# MAIL_PASSWORD: Gmail 앱 비밀번호 (일반 비밀번호 X)
# 발급 방법: Google 계정 > 보안 > 2단계 인증 > 앱 비밀번호
MAIL_USER=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password-16-chars
MAIL_SENDER_NAME=My App                # 발신자 표시 이름
MAIL_CC_DEFAULT=                       # 기본 참조자 이메일 (선택, 비워두어도 됨)

# ── [필수] 텔레그램 알림 ─────────────────────────────────────────
# TELEGRAM_BOT_TOKEN: @BotFather 에서 /newbot 으로 발급
# TELEGRAM_CHAT_ID: @userinfobot 에 메시지를 보내면 확인 가능
TELEGRAM_BOT_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=000000000

# ── [필수] 데이터베이스 ─────────────────────────────────────────
# SQLite (로컬 개발용):
DATABASE_URL=sqlite:///./app.db
# PostgreSQL (프로덕션용):
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ── [개발 옵션] ──────────────────────────────────────────────────
# DEBUG=true 로 설정하면 Google 토큰 미검증 모드로 전환 (개발 환경 전용)
DEBUG=false
